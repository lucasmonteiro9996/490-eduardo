rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin (siteocn@gmail.com) tem acesso total a tudo
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'siteocn@gmail.com';
    }

    // Solicitações de depósito/saque — admin lê/escreve tudo, cliente lê as suas
    match /adminRequests/{docId} {
      allow read, write: if isAdmin();
      allow read: if request.auth != null && request.auth.uid == resource.data.userUid;
      allow create: if request.auth != null;
    }

    // Dados do usuário — admin lê/escreve tudo, cada usuário acessa só o seu
    match /users/{userId} {
      allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);

      match /{subcollection}/{docId} {
        allow read, write: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      }
    }
  }
}
