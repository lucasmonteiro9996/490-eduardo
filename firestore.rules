rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email.lower() == 'siteocn@gmail.com';
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function adminProfileFields() {
      return ['status', 'rejectionReason', 'reviewedAt'];
    }

    match /adminRequests/{docId} {
      allow read: if isAdmin()
        || (request.auth != null && resource.data.userUid == request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.type in ['deposit', 'withdraw']
        && request.resource.data.amount is number
        && request.resource.data.amount > 0;
      allow update: if isAdmin()
        || (request.auth != null
          && resource.data.userUid == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'pending'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['emailStatus', 'emailError', 'updatedAt']));
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.status == 'pending';
      allow update: if isAdmin()
        || (isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(adminProfileFields()));

      match /wallets/{docId} {
        allow read: if isAdmin() || isOwner(userId);
        allow write: if isAdmin();
      }

      match /transactions/{docId} {
        allow read: if isAdmin() || isOwner(userId);
        allow create: if isOwner(userId)
          && request.resource.data.status == 'pending';
        allow update, delete: if isAdmin();
      }

      match /cards/{docId} {
        allow read, write: if isAdmin() || isOwner(userId);
      }

      match /bankAccounts/{docId} {
        allow read, write: if isAdmin() || isOwner(userId);
      }

      match /notifications/{docId} {
        allow read: if isAdmin() || isOwner(userId);
        allow create, delete: if isAdmin();
        allow update: if isAdmin()
          || (isOwner(userId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'updatedAt']));
      }

      match /{subcollection}/{docId} {
        allow read: if isAdmin() || isOwner(userId);
        allow write: if isAdmin();
      }
    }
  }
}
